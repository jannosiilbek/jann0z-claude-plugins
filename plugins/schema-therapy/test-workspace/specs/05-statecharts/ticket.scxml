<!-- supersedes: 04-transitions.md#ticket -->
<scxml version="1.0" xmlns="http://www.w3.org/2005/07/scxml" datamodel="null" initial="reserved">
  <!-- 01-event: Ticket Reserved -->
  <state id="reserved">
    <!-- 01-event: Ticket Sold -->
    <transition event="ticket_sold" target="sold"/>
    <!-- 01-event: Ticket Released -->
    <transition event="ticket_released" target="released"/>
  </state>
  <state id="sold">
    <!-- 01-event: Ticket Cancelled -->
    <transition event="ticket_cancelled" target="cancelled"/>
    <!-- 01-event: Ticket Reissued -->
    <transition event="ticket_reissued" target="reissued"/>
    <!-- 01-event: Ticket Holder Notified -->
    <transition event="ticket_holder_notified" target="holder_notified"/>
    <!-- 01-event: Ticket Admitted -->
    <transition event="ticket_admitted" target="admitted"/>
  </state>
  <final id="released"/>
  <final id="cancelled"/>
  <final id="reissued"/>
  <final id="holder_notified"/>
  <final id="admitted"/>
</scxml>
