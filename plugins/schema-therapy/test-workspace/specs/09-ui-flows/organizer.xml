<IFMLModel id="organizer" persona="Organizer">

  <Realizes taskModel="organizer-open_event"/>
  <Realizes taskModel="organizer-schedule_event"/>
  <Realizes taskModel="organizer-register_venue"/>
  <Realizes taskModel="organizer-define_seating"/>

  <ViewContainer id="organizer_dashboard" name="Organizer Dashboard" home="true">
    <ViewComponent id="event_list" type="list" binding="event"/>
    <ViewComponent id="venue_list" type="list" binding="venue"/>
    <Event id="new_event" type="navigate"/>
    <Event id="open_schedule" type="navigate"/>
    <Event id="new_venue" type="navigate"/>
    <Event id="open_seating" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="event_create" name="New Event">
    <ViewComponent id="event_form" type="form" binding="event"/>
    <Event id="create_event" type="submit" task="enter-event-details" klm="MH3K">
      <!-- 01-event: Event Created -->
    </Event>
    <Event id="back_from_create" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="event_schedule" name="Schedule Event">
    <ViewComponent id="schedule_form" type="form" binding="event"/>
    <Event id="set_dates" type="select" task="assign-event-dates" klm="MPBB"/>
    <Event id="confirm_schedule" type="submit" task="confirm-schedule" klm="MBB">
      <!-- 01-event: Event Scheduled -->
    </Event>
    <Event id="back_from_schedule" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="venue_create" name="Register Venue">
    <ViewComponent id="venue_form" type="form" binding="venue"/>
    <Event id="register_venue" type="submit" task="enter-venue-details" klm="MH3K">
      <!-- 01-event: Venue Registered -->
    </Event>
    <Event id="back_from_venue" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="seating_layout" name="Define Seating">
    <ViewComponent id="seating_form" type="form" binding="venue"/>
    <Event id="set_capacity" type="select" task="enter-section-capacity" klm="MH2K"/>
    <Event id="confirm_seating" type="submit" task="confirm-section" klm="MBB">
      <!-- 01-event: Seating Section Defined -->
    </Event>
    <Event id="back_from_seating" type="navigate"/>
  </ViewContainer>

  <NavigationFlow from="new_event"          to="event_create"/>
  <NavigationFlow from="open_schedule"      to="event_schedule"/>
  <NavigationFlow from="new_venue"          to="venue_create"/>
  <NavigationFlow from="open_seating"       to="seating_layout"/>
  <NavigationFlow from="back_from_create"   to="organizer_dashboard"/>
  <NavigationFlow from="back_from_schedule" to="organizer_dashboard"/>
  <NavigationFlow from="back_from_venue"    to="organizer_dashboard"/>
  <NavigationFlow from="back_from_seating"  to="organizer_dashboard"/>

</IFMLModel>
