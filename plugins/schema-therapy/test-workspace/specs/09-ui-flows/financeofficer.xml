<IFMLModel id="financeofficer" persona="FinanceOfficer">

  <Realizes taskModel="financeofficer-request_refund"/>
  <Realizes taskModel="financeofficer-issue_refund"/>
  <Realizes taskModel="financeofficer-escalate_refund"/>

  <ViewContainer id="refund_queue" name="Refund Queue" home="true">
    <ViewComponent id="refund_list" type="list" binding="refund"/>
    <Event id="open_request" type="navigate"/>
    <Event id="open_issue" type="navigate"/>
    <Event id="open_escalation" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="refund_request" name="Request Refund">
    <ViewComponent id="cancellation_view" type="details" binding="refund"/>
    <Event id="review_cancellation" type="select" task="review-cancellation" klm="MH"/>
    <Event id="submit_request" type="submit" task="submit-refund-request" klm="MBB">
      <!-- 01-event: Refund Requested -->
    </Event>
    <Event id="back_from_request" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="refund_issue" name="Issue Refund">
    <ViewComponent id="payout_view" type="details" binding="refund"/>
    <Event id="authorize_payout" type="submit" task="authorize-payout" klm="MBB">
      <!-- 01-event: Refund Issued -->
    </Event>
    <Event id="back_from_issue" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="refund_escalation" name="Escalate Refund">
    <ViewComponent id="failure_view" type="details" binding="refund"/>
    <Event id="diagnose_failure" type="select" task="diagnose-failure" klm="MH"/>
    <Event id="hand_to_finance" type="submit" task="hand-to-finance" klm="MBB">
      <!-- 01-event: Refund Escalated -->
    </Event>
    <Event id="back_from_escalation" type="navigate"/>
  </ViewContainer>

  <NavigationFlow from="open_request"        to="refund_request"/>
  <NavigationFlow from="open_issue"          to="refund_issue"/>
  <NavigationFlow from="open_escalation"     to="refund_escalation"/>
  <NavigationFlow from="back_from_request"   to="refund_queue"/>
  <NavigationFlow from="back_from_issue"     to="refund_queue"/>
  <NavigationFlow from="back_from_escalation" to="refund_queue"/>

</IFMLModel>
