<IFMLModel id="customer" persona="Customer">

  <Realizes taskModel="customer-place_order"/>
  <Realizes taskModel="customer-buy_ticket"/>
  <Realizes taskModel="customer-cancel_ticket"/>
  <Realizes taskModel="customer-join_waitlist"/>

  <ViewContainer id="customer_home" name="My Tickets" home="true">
    <ViewComponent id="ticket_list" type="list" binding="ticket"/>
    <ViewComponent id="order_list" type="list" binding="order"/>
    <Event id="start_order" type="navigate"/>
    <Event id="open_payment" type="navigate"/>
    <Event id="start_cancel" type="navigate"/>
    <Event id="open_waitlist" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="order_compose" name="New Order">
    <ViewComponent id="order_form" type="form" binding="order"/>
    <Event id="pick_tickets" type="select" task="select-tickets" klm="MPBB"/>
    <Event id="place_order" type="submit" task="submit-order" klm="MBB">
      <!-- 01-event: Order Placed -->
    </Event>
    <Event id="back_from_order" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="order_payment" name="Pay Order">
    <ViewComponent id="payment_view" type="details" binding="order"/>
    <Event id="pay_order" type="submit" task="pay-order" klm="MH2K">
      <!-- 01-event: Order Paid -->
    </Event>
    <Event id="back_from_payment" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="ticket_cancel" name="Cancel Ticket">
    <ViewComponent id="ticket_view" type="details" binding="ticket"/>
    <Event id="pick_ticket" type="select" task="select-ticket" klm="MPBB"/>
    <Event id="confirm_cancel" type="submit" task="confirm-cancel" klm="MBB">
      <!-- 01-event: Ticket Cancelled -->
    </Event>
    <Event id="back_from_cancel" type="navigate"/>
  </ViewContainer>

  <ViewContainer id="waitlist_join" name="Join Waitlist">
    <ViewComponent id="waitlist_form" type="form" binding="waitlist_offer"/>
    <Event id="join_waitlist" type="submit" task="request-join" klm="MPBB">
      <!-- 01-event: Waitlist Joined -->
    </Event>
    <Event id="back_from_waitlist" type="navigate"/>
  </ViewContainer>

  <NavigationFlow from="start_order"        to="order_compose"/>
  <NavigationFlow from="open_payment"       to="order_payment"/>
  <NavigationFlow from="start_cancel"       to="ticket_cancel"/>
  <NavigationFlow from="open_waitlist"      to="waitlist_join"/>
  <NavigationFlow from="back_from_order"    to="customer_home"/>
  <NavigationFlow from="back_from_payment"  to="customer_home"/>
  <NavigationFlow from="back_from_cancel"   to="customer_home"/>
  <NavigationFlow from="back_from_waitlist" to="customer_home"/>

</IFMLModel>
