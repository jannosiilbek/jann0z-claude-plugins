// 04-erd.dbml — data model for the order/coupon domain.

Enum OrderStatus {
  placed
  paid
  shipped
  delivered
  cancelled
  refunded
}

Enum CouponStatus {
  issued
  redeemed
  expired
}

Table Order {
  id integer [primary key]
  status OrderStatus
  customer_id integer
}

Table Coupon {
  id integer [primary key]
  status CouponStatus
  order_id integer
}
