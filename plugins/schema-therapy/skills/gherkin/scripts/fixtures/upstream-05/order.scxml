<?xml version="1.0" encoding="UTF-8"?>
<!-- fingerprints: 04-transitions.md@sha256:deadbeef -->
<!-- supersedes: 04-transitions.md#Order -->
<scxml xmlns="http://www.w3.org/2005/07/scxml" version="1.0" datamodel="null" initial="placed">
  <!-- 01-event: Order Placed -->
  <state id="placed">
    <!-- 01-event: Order Paid -->
    <transition event="order_paid" target="paid"/>
    <!-- 01-event: Order Cancelled -->
    <transition event="order_cancelled" target="cancelled"/>
  </state>
  <state id="paid">
    <!-- 01-event: Order Shipped -->
    <transition event="order_shipped" target="shipped"/>
  </state>
  <state id="shipped">
    <!-- 01-event: Order Delivered -->
    <transition event="order_delivered" target="delivered"/>
  </state>
  <state id="delivered">
    <!-- 01-event: Order Refunded -->
    <transition event="order_refunded" target="refunded"/>
  </state>
  <final id="cancelled"/>
  <final id="refunded"/>
</scxml>
