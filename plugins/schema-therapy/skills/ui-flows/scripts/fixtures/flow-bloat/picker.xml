<IFMLModel id="picker" persona="Picker">

  <Realizes taskModel="picker-pick_order"/>

  <ViewContainer id="pick_list" name="Pick List" home="true">
    <ViewComponent id="picks_list" type="list" binding="line_item"/>
    <Event id="open_picks" type="select" task="open-pick-list" klm="MBB"/>
  </ViewContainer>

  <ViewContainer id="pick_detail" name="Pick Detail">
    <ViewComponent id="pick_view" type="details" binding="line_item"/>
    <Event id="confirm_pick" type="submit" task="confirm-pick" klm="MBB"/>
    <Event id="back_picks" type="navigate"/>
  </ViewContainer>

  <NavigationFlow from="open_picks" to="pick_detail"/>
  <NavigationFlow from="back_picks" to="pick_list"/>

</IFMLModel>
