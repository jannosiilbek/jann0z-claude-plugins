          <association xmi:idref="IFML-Core-A_event_interactionFlowExpression"/>
        </ownedAttribute>
        <name>Event</name>
      </packagedElement>
      <packagedElement xmi:id="IFML-Core-A_event_activationExpression" xmi:uuid="725A27D7-D6DA-4DC9-9D60-1C8CDBCF9AB6" xmi:type="uml:Association">
