// 03-aggregates.md@sha256:1b2c3d4e5f60718293a4b5c6d7e8f9001122334455667788990aabbccddeeff0

Enum order_status {
  placed
  paid
  expired
}

Enum ticket_status {
  reserved
  sold
  released
}

Table order {
  id int [not null]
  status order_status [not null]
}
Table ticket {
  id int [pk, increment]
  seat_number varchar [not null]
  status ticket_status [not null]
}
Table order_ticket {
  order_id int [not null]
  ticket_id int [not null]
  indexes { (order_id, ticket_id) [pk] }
}
Ref: order_ticket.order_id > order.id
Ref: order_ticket.ticket_id > ticket.id
